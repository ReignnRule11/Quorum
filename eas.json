{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_URL": "https://quorum-backend-1.onrender.com",
        "STRIPE_PUBLISHABLE_KEY": "pk_live_xxxxxxxxxxxxxxxx"
      },
      "android": {
        "buildType": "aab"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your-apple-id@example.com",
        "ascAppId": "1234567890",
        "sku": "quorum.voting.1"
      },
      "android": {
        "track": "production",
        "releaseStatus": "completed"
      }
    }
  }
}
